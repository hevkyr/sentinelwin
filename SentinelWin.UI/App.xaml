<Application x:Class="SentinelWin.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Dark theme tokens -->
            <SolidColorBrush x:Key="Bg"        Color="#0B1020"/>
            <SolidColorBrush x:Key="Surface"   Color="#121831"/>
            <SolidColorBrush x:Key="Border"    Color="#1F2A4A"/>
            <SolidColorBrush x:Key="Text"      Color="#E6EAF5"/>
            <SolidColorBrush x:Key="Muted"     Color="#8A93B2"/>
            <SolidColorBrush x:Key="Accent"    Color="#3DDC97"/>
            <SolidColorBrush x:Key="RiskHigh"  Color="#FF5C7A"/>
            <SolidColorBrush x:Key="RiskMed"   Color="#FFB454"/>
            <SolidColorBrush x:Key="RiskLow"   Color="#3DDC97"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
