<Window x:Class="SentinelWin.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SentinelWin — Privacy &amp; Security Agent"
        Height="820" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Score color converters via DataTriggers applied in code -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="#0B1020"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#1F2A4A"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="#3D1020"/>
            <Setter Property="Foreground" Value="{StaticResource RiskHigh}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource RiskHigh}"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>   <!-- header -->
            <RowDefinition Height="Auto"/> <!-- toolbar -->
            <RowDefinition Height="*"/>    <!-- main content -->
            <RowDefinition Height="120"/>  <!-- action log -->
            <RowDefinition Height="28"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════ HEADER ═══════════════ -->
        <Border Grid.Row="0" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡️" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="SentinelWin" Foreground="{StaticResource Text}"
                               FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="  Privacy &amp; Security Agent"
                               Foreground="{StaticResource Muted}"
                               FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <!-- Score badge -->
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Score:" Foreground="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ScoreLabel"
                               Text="{Binding ScoreLabel}"
                               Foreground="{StaticResource Accent}"
                               FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════ TOOLBAR ═══════════════ -->
        <Border Grid.Row="1" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="24,10" VerticalAlignment="Center">
                <Button x:Name="ScanBtn" Content="🔍  Scan Now"
                        Style="{StaticResource PrimaryBtn}"
                        Click="ScanBtn_Click"
                        IsEnabled="{Binding IsIdle}"/>

                <Button x:Name="ApplyBtn" Content="⚡ Apply Fix"
                        Style="{StaticResource SecondaryBtn}"
                        Click="ApplyBtn_Click"
                        IsEnabled="{Binding IsIdle}"
                        Margin="10,0,0,0"/>

                <Separator Width="1" Background="{StaticResource Border}" Margin="16,0"/>

                <CheckBox x:Name="DryRunCheck"
                          Content="Dry-run mode (preview only)"
                          IsChecked="{Binding IsDryRun, Mode=TwoWay}"
                          Foreground="{StaticResource Text}"
                          VerticalAlignment="Center"/>

                <!-- Busy indicator -->
                <TextBlock Text="⟳ Working..."
                           Foreground="{StaticResource Accent}"
                           VerticalAlignment="Center" Margin="20,0,0,0"
                           Visibility="{Binding IsBusy,
                               Converter={x:Static BooleanToVisibilityConverter}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="240"/>
            </Grid.ColumnDefinitions>

            <!-- Results DataGrid -->
            <Border Grid.Column="0" Margin="16,12,8,0"
                    Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                    CornerRadius="6">
                <DataGrid x:Name="ResultsGrid"
                          ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          Background="Transparent"
                          Foreground="{StaticResource Text}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0D1530"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource Border}"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="ResultsGrid_SelectionChanged"
                          ColumnHeaderHeight="34">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type"   Binding="{Binding Type}"   Width="90"/>
                        <DataGridTextColumn Header="Name"   Binding="{Binding Name}"   Width="200"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                        <DataGridTextColumn Header="Risk"   Binding="{Binding Risk}"   Width="80"/>
                        <DataGridCheckBoxColumn Header="OK" Binding="{Binding IsCompliant}" Width="50"/>
                        <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="*"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCompliant}" Value="False">
                                    <Setter Property="Foreground" Value="{StaticResource RiskHigh}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsCompliant}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource RiskLow}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Border>

            <!-- Snapshots / Rollback panel -->
            <Border Grid.Column="1" Margin="8,12,16,0"
                    Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                    CornerRadius="6" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Snapshots"
                               Foreground="{StaticResource Muted}"
                               FontSize="11" FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               TextOptions.TextFormattingMode="Display"/>
                    <Button DockPanel.Dock="Bottom" Content="↩  Rollback Selected"
                            Style="{StaticResource DangerBtn}"
                            Click="RollbackBtn_Click"
                            Margin="0,8,0,0"/>
                    <ListBox x:Name="SnapshotList"
                             ItemsSource="{Binding SnapshotIds}"
                             Background="Transparent"
                             Foreground="{StaticResource Text}"
                             BorderThickness="0"
                             FontFamily="Consolas" FontSize="11"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══════════════ ACTION LOG ═══════════════ -->
        <Border Grid.Row="3" Margin="16,8,16,0"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="1"
                CornerRadius="6" Padding="10,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Action Log"
                           Foreground="{StaticResource Muted}"
                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ListBox ItemsSource="{Binding ActionLog}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource Text}"
                         FontFamily="Consolas" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══════════════ STATUS BAR ═══════════════ -->
        <Border Grid.Row="4" Background="#0A0E1A"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource Muted}"
                       FontSize="11" VerticalAlignment="Center"
                       Margin="24,0" TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
